rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 읽기: 모두 허용 (공개 페이지에서 통계 조회 필요)
    // 쓰기: 로그인된 관리자만
    function isAdmin() {
      return request.auth != null;
    }

    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 명시되지 않은 컬렉션은 모두 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
